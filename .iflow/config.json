{"version": "1.0.0", "project": {"name": "tutly", "type": "flutter", "description": "Mini city guide for Ufa - MVP"}, "tdd": {"enabled": true, "enforceOnCommit": true, "requireTestsForNewCode": true, "failOnMissingTests": true, "failOnTestFailure": true}, "test": {"framework": "flutter_test", "directories": ["test/unit", "test/widget", "test/integration"], "patterns": {"unit": "test/unit/*_test.dart", "widget": "test/widget/*_test.dart", "integration": "test/integration/*_test.dart"}, "coverage": {"enabled": false, "minCoverage": 80}}, "hooks": {"preCommit": {"enabled": true, "script": ".git/hooks/pre-commit.ps1", "description": "Validate tests before commit"}, "prePush": {"enabled": false}}, "scripts": {"validate": "powershell -ExecutionPolicy Bypass -File .iflow/scripts/validate-tests.ps1", "createTest": "powershell -ExecutionPolicy Bypass -File .iflow/scripts/create-test-template.ps1 -SourceFile", "test": "flutter test", "testCoverage": "flutter test --coverage"}, "validation": {"analyze": {"enabled": true, "command": "flutter analyze", "failOnError": true}, "format": {"enabled": true, "command": "dart format .", "checkOnly": true}}, "workflow": {"beforeCodeChange": ["validate"], "afterCodeChange": ["test", "analyze"]}, "notifications": {"onTestFailure": true, "onMissingTest": true, "onSuccess": true}}